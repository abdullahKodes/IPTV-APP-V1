<?xml version="1.0" encoding="utf-8"?>
<component name="SeriesPage" extends="Group">
  <children>
    <!-- Series renders genre filters, continue-watching cards, and popular series grid. -->
    <Group id="seriesCanvas" />
  </children>
  <interface>
    <field id="navigateTo" type="string" alwaysNotify="true" />
    <field id="playbackTitle" type="string" />
    <field id="playbackSubtitle" type="string" />
    <field id="playbackUrl" type="string" />
    <field id="playbackFormat" type="string" />
    <field id="playbackPosterUrl" type="string" />
    <field id="returnPage" type="string" />
    <function name="handleKey" />
    <function name="refreshClock" />
  </interface>
  <script type="text/brightscript" uri="pkg:/components/shared/AppUi.brs" />
  <script type="text/brightscript" uri="pkg:/components/shared/MediaData.brs" />
  <script type="text/brightscript" uri="pkg:/components/pages/SeriesPage.brs" />
</component>
