<?xml version="1.0" encoding="utf-8"?>
<component name="LiveTvPage" extends="Group">
  <children>
    <!-- Live TV renders channel categories, channel list, player mock, controls, and EPG strip. -->
    <Group id="liveTvCanvas" />
    <Video id="livePlayerVideo" />
    <Group id="liveTvOverlay" />
  </children>
  <interface>
    <field id="navigateTo" type="string" alwaysNotify="true" />
    <function name="handleKey" />
    <function name="refreshClock" />
  </interface>
  <script type="text/brightscript" uri="pkg:/components/shared/AppUi.brs" />
  <script type="text/brightscript" uri="pkg:/components/shared/PlaylistStore.brs" />
  <script type="text/brightscript" uri="pkg:/components/shared/MediaData.brs" />
  <script type="text/brightscript" uri="pkg:/components/shared/FavoriteStore.brs" />
  <script type="text/brightscript" uri="pkg:/components/pages/LiveTvPage.brs" />
</component>
